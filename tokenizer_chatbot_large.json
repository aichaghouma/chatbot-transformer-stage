    # ---------------- RESEAUX : PROTOCOLES ----------------
    {"subject": "Networking", "title": "ARP protocol",
     "content": "ARP (Address Resolution Protocol) is used to map an IP address to a physical MAC address on a local network, allowing devices to communicate at the hardware level."},
    {"subject": "Networking", "title": "ICMP protocol",
     "content": "ICMP (Internet Control Message Protocol) is used to send error messages and operational information about network conditions, such as when a destination is unreachable. It is the basis of the ping command."},
    {"subject": "Networking", "title": "SMTP protocol",
     "content": "SMTP (Simple Mail Transfer Protocol) is used to send emails from a client to a server or between mail servers across the internet."},
    {"subject": "Networking", "title": "FTP protocol",
     "content": "FTP (File Transfer Protocol) is used to transfer files between a client and a server over a network, allowing users to upload, download, and manage files remotely."},
    {"subject": "Networking", "title": "DHCP protocol",
     "content": "DHCP (Dynamic Host Configuration Protocol) automatically assigns IP addresses and other network configuration settings (like the default gateway and DNS) to devices when they join a network."},
    {"subject": "Networking", "title": "NAT (Network Address Translation)",
     "content": "NAT (Network Address Translation) allows multiple devices on a private network to share a single public IP address when accessing the internet, translating private addresses to the public one."},
    {"subject": "Networking", "title": "Telnet protocol",
     "content": "Telnet is an older protocol used for remote access to devices over a network, but it sends data (including passwords) in plain text, making it insecure compared to SSH."},
    {"subject": "Networking", "title": "MAC address",
     "content": "A MAC (Media Access Control) address is a unique hardware identifier assigned to a device's network interface, used for communication within a local network at the data link layer."},
    {"subject": "Networking", "title": "Ethernet",
     "content": "Ethernet is a widely used technology for wired local area networks (LANs), defining how devices format and transmit data over physical cables, standardized as IEEE 802.3."},
    {"subject": "Networking", "title": "Default gateway",
     "content": "A default gateway is the device (usually a router) that forwards network traffic from a local network to other networks or the internet when the destination is outside the local network."},
    {"subject": "Networking", "title": "Subnetting",
     "content": "Subnetting is the process of dividing a larger network into smaller sub-networks (subnets), improving network organization, performance, and security."},
    {"subject": "Networking", "title": "Unicast, multicast, broadcast",
     "content": "Unicast sends data from one sender to one specific receiver, multicast sends data to a selected group of receivers, and broadcast sends data to all devices on a network."},
    {"subject": "Networking", "title": "MTU",
     "content": "MTU (Maximum Transmission Unit) is the largest size of a data packet that can be transmitted over a network in a single unit without needing to be fragmented."},
    {"subject": "Networking", "title": "POP3 and IMAP",
     "content": "POP3 and IMAP are protocols used to retrieve emails from a mail server. POP3 downloads and typically removes messages from the server, while IMAP keeps messages synchronized on the server across multiple devices."},
    {"subject": "Networking", "title": "SNMP protocol",
     "content": "SNMP (Simple Network Management Protocol) is used to monitor and manage network devices such as routers, switches, and servers, collecting performance data and alerts."},
    {"subject": "Networking", "title": "CIDR notation",
     "content": "CIDR (Classless Inter-Domain Routing) is a method for allocating IP addresses using a suffix (e.g., /24) to indicate how many bits of an IP address represent the network portion."},
    {"subject": "Networking", "title": "SSH protocol",
     "content": "SSH (Secure Shell) is a protocol that provides secure, encrypted remote access to a computer or server over a network, commonly used for remote administration."},

    # ---------------- RESEAUX : COMMANDES ----------------
    {"subject": "Networking", "title": "Ping command",
     "content": "The ping command tests connectivity between two devices on a network by sending ICMP echo requests and measuring the response time, helping diagnose network issues."},
    {"subject": "Networking", "title": "Traceroute command",
     "content": "The traceroute command shows the path (sequence of routers/hops) that data packets take to reach a destination, helping diagnose where delays or failures occur on a network."},
    {"subject": "Networking", "title": "Nslookup command",
     "content": "The nslookup command is used to query DNS servers to find the IP address associated with a domain name, or vice versa, useful for troubleshooting DNS issues."},
    {"subject": "Networking", "title": "Netstat command",
     "content": "The netstat command displays active network connections, listening ports, and related statistics on a computer, useful for network troubleshooting and monitoring."},

    # ---------------- RESEAUX : DIAGNOSTIC ----------------
    {"subject": "Networking", "title": "Network troubleshooting",
     "content": "Diagnosing a network failure typically involves checking physical connections, testing connectivity with ping, tracing the route with traceroute, verifying DNS resolution, and checking device configurations."},
    {"subject": "Networking", "title": "Packet loss",
     "content": "Packet loss occurs when data packets fail to reach their destination during transmission, often caused by network congestion, faulty hardware, or signal interference, degrading connection quality."},
    {"subject": "Networking", "title": "Network latency",
     "content": "Network latency is the time delay between sending a data packet and it arriving at its destination, usually measured in milliseconds, affecting the responsiveness of online applications."},
    {"subject": "Networking", "title": "Bandwidth vs throughput",
     "content": "Bandwidth is the maximum theoretical data transfer capacity of a network connection, while throughput is the actual amount of data successfully transferred in practice, often lower than the bandwidth."},

    # ---------------- RESEAUX : ROUTAGE ----------------
    {"subject": "Networking", "title": "Static vs dynamic routing",
     "content": "Static routing uses manually configured routes that do not change automatically, while dynamic routing uses protocols (like OSPF or RIP) that automatically adjust routes based on current network conditions."},
    {"subject": "Networking", "title": "Routing table",
     "content": "A routing table is a data set stored in a router that lists the paths to different network destinations, used to determine the best route for forwarding data packets."},
    {"subject": "Networking", "title": "OSPF protocol",
     "content": "OSPF (Open Shortest Path First) is a dynamic routing protocol that uses the shortest path algorithm to determine the best route for data within a network, commonly used in large enterprise networks."},
    {"subject": "Networking", "title": "RIP protocol",
     "content": "RIP (Routing Information Protocol) is a simple dynamic routing protocol that uses hop count to determine the best path, suitable for small networks but less efficient for large ones."},
    {"subject": "Networking", "title": "BGP protocol",
     "content": "BGP (Border Gateway Protocol) is the routing protocol used to exchange routing information between large networks (autonomous systems) on the internet, forming the backbone of internet routing."},

    # ---------------- RESEAUX : COMMUTATION AVANCEE ----------------
    {"subject": "Networking", "title": "Trunk port vs access port",
     "content": "An access port carries traffic for a single VLAN and is typically connected to end devices, while a trunk port carries traffic for multiple VLANs, typically connecting switches together."},
    {"subject": "Networking", "title": "Spanning Tree Protocol (STP)",
     "content": "STP (Spanning Tree Protocol) prevents network loops in switched networks by automatically disabling redundant paths, while keeping them available as backups if the active path fails."},
    {"subject": "Networking", "title": "RSTP protocol",
     "content": "RSTP (Rapid Spanning Tree Protocol) is an improved version of STP that detects and resolves network loops much faster, reducing network downtime during topology changes."},
    {"subject": "Networking", "title": "Port security",
     "content": "Port security is a switch feature that restricts which devices (by MAC address) can connect to a specific port, helping prevent unauthorized access to the network."},
    {"subject": "Networking", "title": "VTP protocol",
     "content": "VTP (VLAN Trunking Protocol) allows network administrators to manage and synchronize VLAN configurations across multiple switches automatically, reducing manual configuration."},
    {"subject": "Networking", "title": "LACP protocol",
     "content": "LACP (Link Aggregation Control Protocol) combines multiple physical network links into a single logical link, increasing bandwidth and providing redundancy between switches."},

    # ---------------- RESEAUX : WIFI ----------------
    {"subject": "Networking", "title": "Wi-Fi",
     "content": "Wi-Fi is a wireless networking technology that allows devices to connect to a local network and the internet using radio waves, based on the IEEE 802.11 standards."},
    {"subject": "Networking", "title": "2.4GHz vs 5GHz Wi-Fi",
     "content": "The 2.4GHz Wi-Fi band offers longer range but slower speeds and more interference, while the 5GHz band offers faster speeds and less interference but shorter range."},
    {"subject": "Networking", "title": "Wi-Fi 6",
     "content": "Wi-Fi 6 (802.11ax) is a wireless standard offering faster speeds, better performance in crowded areas, and improved battery efficiency for connected devices compared to previous Wi-Fi generations."},
    {"subject": "Networking", "title": "WPA2 vs WPA3",
     "content": "WPA2 and WPA3 are Wi-Fi security protocols; WPA3 is the newer standard, offering stronger encryption and better protection against password-guessing attacks compared to WPA2."},
    {"subject": "Networking", "title": "SSID",
     "content": "An SSID (Service Set Identifier) is the name of a Wi-Fi network, displayed to users when searching for available wireless networks to connect to."},
    {"subject": "Networking", "title": "Wi-Fi roaming",
     "content": "Wi-Fi roaming allows a device to seamlessly switch between different access points within the same network as the user moves, maintaining a continuous connection."},
    {"subject": "Networking", "title": "Securing a Wi-Fi network",
     "content": "Securing a Wi-Fi network involves using strong encryption (WPA3 if available), setting a strong password, disabling WPS, hiding or renaming the default SSID, and keeping router firmware updated."},
    {"subject": "Networking", "title": "Bluetooth",
     "content": "Bluetooth is a short-range wireless technology used to connect devices like headphones, keyboards, and speakers, typically operating within a range of about 10 meters."},
    {"subject": "Networking", "title": "NFC",
     "content": "NFC (Near Field Communication) is a very short-range wireless technology (a few centimeters) used for tasks like contactless payments and quick device pairing."},

    # ---------------- RESEAUX AVANCE : SECURITE ET CLOUD ----------------
    {"subject": "Networking", "title": "Proxy server",
     "content": "A proxy server acts as an intermediary between a client and the internet, forwarding requests on behalf of the user, often used for caching, filtering, or hiding the user's IP address."},
    {"subject": "Networking", "title": "Proxy vs VPN",
     "content": "A proxy redirects traffic for specific applications and does not encrypt data, while a VPN encrypts all internet traffic from the device and routes it through a secure tunnel, offering stronger privacy."},
    {"subject": "Networking", "title": "Quality of Service (QoS)",
     "content": "QoS (Quality of Service) refers to techniques used to prioritize certain types of network traffic (like video calls) over others, ensuring better performance for critical applications."},
    {"subject": "Networking", "title": "Software-Defined Networking (SDN)",
     "content": "SDN (Software-Defined Networking) is an approach that separates network control logic from physical hardware, allowing centralized, programmable management of network behavior."},
    {"subject": "Networking", "title": "Cloud networking",
     "content": "Cloud networking refers to managing and connecting network resources (routers, firewalls, load balancers) that are hosted in the cloud rather than on physical, on-premises hardware."},
    {"subject": "Networking", "title": "Network virtualization",
     "content": "Network virtualization combines physical network resources into a single, software-based virtual network, allowing more flexible and efficient management independent of the underlying hardware."},
    {"subject": "Networking", "title": "VXLAN",
     "content": "VXLAN (Virtual Extensible LAN) is a network virtualization technology that allows the creation of large-scale virtual networks across data centers, overcoming the limitations of traditional VLANs."},
    {"subject": "Networking", "title": "Data center",
     "content": "A data center is a facility housing computing infrastructure (servers, storage, networking equipment) used to store, process, and distribute large amounts of data for organizations."},

    # ---------------- RESEAUX NIVEAU INGENIEUR ----------------
    {"subject": "Networking", "title": "TCP protocol operation",
     "content": "TCP (Transmission Control Protocol) establishes a reliable, ordered connection between two devices, using acknowledgments and retransmissions to ensure data is delivered correctly and completely."},
    {"subject": "Networking", "title": "DNS resolution process",
     "content": "DNS resolution works by a client asking a DNS resolver, which queries root, top-level domain (TLD), and authoritative name servers in sequence until it finds the IP address matching the requested domain name."},
    {"subject": "Networking", "title": "TCP three-way handshake",
     "content": "The TCP three-way handshake establishes a connection using three steps: the client sends a SYN, the server responds with SYN-ACK, and the client replies with ACK, after which data transfer can begin."},
    {"subject": "Networking", "title": "TCP congestion control",
     "content": "TCP congestion control manages the rate of data transmission to avoid overwhelming the network, using mechanisms like slow start and congestion avoidance to adjust sending speed based on network conditions."},
    {"subject": "Networking", "title": "Load balancing",
     "content": "Load balancing distributes incoming network traffic across multiple servers, improving performance, reliability, and preventing any single server from becoming overwhelmed."},
    {"subject": "Networking", "title": "Man-in-the-Middle attack",
     "content": "A Man-in-the-Middle (MITM) attack occurs when an attacker secretly intercepts and possibly alters communication between two parties who believe they are directly communicating with each other."},
    {"subject": "Networking", "title": "HTTPS protocol",
     "content": "HTTPS (HTTP Secure) is the secure version of HTTP, encrypting data exchanged between a browser and a website using TLS/SSL, protecting against eavesdropping and tampering."},

    # ---------------- INFORMATIQUE GENERALE : COMPLEMENTS ----------------
